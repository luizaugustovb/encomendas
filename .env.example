# ============================================
# Variáveis de Ambiente
# ============================================
# Produção: copie para .env e preencha os valores reais
# Para Docker: use docker-compose.prod.yml (host do DB = postgres)
# ============================================

# ===== DATABASE =====
# Dev: localhost:5433 | Docker prod: postgres:5432
DATABASE_URL=postgresql://encomendas:encomendas123@localhost:5433/encomendas_db
POSTGRES_USER=encomendas
POSTGRES_PASSWORD=encomendas123
POSTGRES_DB=encomendas_db

# ===== REDIS =====
# Dev: localhost | Docker prod: redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== JWT =====
JWT_SECRET=TROQUE-POR-STRING-LONGA-ALEATORIA
JWT_EXPIRES_IN=7d

# ===== APP =====
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development

# ===== WHATSAPP (VIICIO) =====
WHATSAPP_API_URL=https://api.viicio.com.br
WHATSAPP_API_TOKEN=your-viicio-token-here

# ===== MASTER ADMIN =====
MASTER_EMAIL=admin@example.com
MASTER_PASSWORD=change-this-password

# ===== CORS (produção) =====
# Domínios separados por vírgula
CORS_ORIGIN=https://seudominio.com

# ===== DOMÍNIO (SSL) =====
DOMAIN=seudominio.com
